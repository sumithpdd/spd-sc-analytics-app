# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.
# Restart the dev server after changing these values.

# -----------------------------------------------------------------------
# OAuth2 Automation Client (Word import)
#
# Used by /api/create-article to authenticate with the Sitecore Authoring API.
# Get these from XM Cloud Deploy (NOT Developer Studio):
#
#   1. Open https://deploy.sitecorecloud.io
#   2. Select Project → Environment → Credentials
#   3. Create credentials → Automation
#   4. Name it (e.g. "spd-marketplace-app") → Create
#   5. Copy Client ID and Client Secret NOW — secret is shown only once
# -----------------------------------------------------------------------
SITECORE_CLIENT_ID=your-automation-client-id
SITECORE_CLIENT_SECRET=your-automation-client-secret

# -----------------------------------------------------------------------
# XM Cloud CM Hostname
#
# Your Content Management host. No https:// or trailing slash.
# Find in XM Cloud Deploy → Environment → CM URL.
#
# Examples: xmcloudcm.localhost  |  xmc-xxx.sitecorecloud.io
# -----------------------------------------------------------------------
XMC_HOST=xmcloudcm.localhost

# -----------------------------------------------------------------------
# Articles Folder Item ID  (required for Word import)
#
# The Authoring API needs a GUID for createItem parent, not a path.
# Content Editor → /sitecore/.../Home/Articles → Quick Info → Item ID
# Paste WITHOUT curly braces.
# -----------------------------------------------------------------------
ARTICLES_FOLDER_ID=your-articles-folder-guid

# -----------------------------------------------------------------------
# Optional overrides (defaults are in lib/sitecore-constants.ts)
# -----------------------------------------------------------------------
# AUTHOR_ITEM_TEMPLATE_ID={AE7C9FA3-F2CB-4A02-8781-789897E12044}
